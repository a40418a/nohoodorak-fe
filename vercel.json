{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://3.34.194.35:8080/api/:path*"
    },
    {
      "source": "/auth/refresh",
      "destination": "http://3.34.194.35:8080/auth/refresh"
    },
    {
      "source": "/auth/kakao/callback",
      "destination": "http://3.34.194.35:8080/auth/kakao/callback"
    },
    {
      "source": "/((?!api|auth/refresh|auth/kakao/callback|assets|favicon\\.ico|robots\\.txt|manifest\\.json|service-worker\\.js).*)",
      "destination": "/index.html"
    }
  ]
}
